PORT=5000
DB_NAME=fairplay_auction
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
JWT_SECRET=change_this_to_a_long_random_secret

# For cloud (Render / Railway / Heroku) — replaces DB_NAME/USER/PASSWORD/HOST:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# For Redis (BullMQ background jobs) — optional, queues degrade gracefully without it:
# REDIS_URL=redis://localhost:6379
